<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>4MC - Premium Scripts & Resources</title>
    <meta name="description" content="4MC is your trusted source for high-quality, premium resources designed to elevate your projects.">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
    <canvas id="network-canvas" class="network-canvas" aria-hidden="true"></canvas>
    <div class="grid-overlay"></div>

    <div class="bg-effects">
        <div class="glow-blob glow-blob-1"></div>
        <div class="glow-blob glow-blob-2"></div>
        <div class="glow-blob glow-blob-3"></div>
    </div>

    <header class="topbar">
        <a href="/" class="brand">
            <span class="brand-icon"><i class="fas fa-bolt"></i></span>
            <span class="brand-text"><strong>4MC</strong></span>
        </a>
        <nav class="topbar-nav">
            <a href="/" class="active"><i class="fas fa-house"></i> Home</a>
            <a href="#"><i class="fas fa-layer-group"></i> Resources</a>
            <a href="#"><i class="fas fa-wrench"></i> Toolkit</a>
            <a href="#"><i class="fas fa-book-open"></i> Guides</a>
        </nav>
        <div class="topbar-actions">
            <% if (user) { %>
                <a href="/dashboard" class="btn btn-ghost"><i class="fas fa-right-to-bracket"></i> Dashboard</a>
            <% } else { %>
                <a href="/auth/login" class="btn btn-primary"><i class="fas fa-right-to-bracket"></i> Login</a>
            <% } %>
        </div>
    </header>

    <main class="page-home">
        <section class="hero">
            <div class="hero-content">
                <div class="hero-badge reveal">
                    <span class="badge-dot"></span>
                    <span>Community Driven</span>
                </div>
                <h1 class="hero-title reveal">
                    The Ultimate Platform for<br>
                    <span class="gradient-text">Premium Resources</span>
                </h1>
                <p class="hero-subtitle reveal">
                    Access high-quality scripts, maps, vehicles, and more — completely free.
                    Built by the community, for the community.
                </p>
                <div class="hero-actions reveal">
                    <% if (user) { %>
                        <a href="/dashboard" class="btn btn-lg btn-primary">
                            <i class="fas fa-rocket"></i> Go to Dashboard
                        </a>
                    <% } else { %>
                        <a href="/auth/login" class="btn btn-lg btn-primary">
                            <i class="fas fa-rocket"></i> Get Started Free
                        </a>
                        <a href="/auth/login" class="btn btn-lg btn-discord">
                            <i class="fab fa-discord"></i> Login with Discord
                        </a>
                    <% } %>
                </div>
                <div class="hero-stats reveal">
                    <div class="stat">
                        <div class="stat-icon"><i class="fas fa-download"></i></div>
                        <div class="stat-value">141,754</div>
                        <div class="stat-label">Downloads</div>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat">
                        <div class="stat-icon"><i class="fas fa-star"></i></div>
                        <div class="stat-value">723</div>
                        <div class="stat-label">Resources</div>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat">
                        <div class="stat-icon"><i class="fas fa-users"></i></div>
                        <div class="stat-value">6,083</div>
                        <div class="stat-label">Members</div>
                    </div>
                </div>
            </div>
        </section>

        <section class="features">
            <div class="section-header">
                <span class="section-label"><i class="fas fa-sparkles"></i> Why Choose 4MC</span>
                <h2 class="section-title">Everything you need to<br><span class="gradient-text">power your server</span></h2>
            </div>
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon-box icon-purple">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <h3>Lightning Fast</h3>
                    <p>Instant access to high-speed downloads. No waiting, no limits.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon-box icon-green">
                        <i class="fas fa-shield-halved"></i>
                    </div>
                    <h3>Verified & Safe</h3>
                    <p>Every resource is reviewed and verified for security and quality.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon-box icon-blue">
                        <i class="fas fa-user-group"></i>
                    </div>
                    <h3>Active Community</h3>
                    <p>Thousands of creators sharing, reviewing, and improving daily.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon-box icon-orange">
                        <i class="fas fa-arrows-rotate"></i>
                    </div>
                    <h3>Regular Updates</h3>
                    <p>New resources added every week. Fresh content, always evolving.</p>
                </div>
            </div>
        </section>

        <section class="cta-section">
            <div class="cta-card">
                <div class="cta-glow"></div>
                <h2>Ready to get started?</h2>
                <p>Join thousands of users already using 4MC for their server needs.</p>
                <a href="/auth/login" class="btn btn-lg btn-primary">
                    <i class="fab fa-discord"></i> Join the Community
                </a>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="footer-inner">
            <div class="footer-grid">
                <div class="footer-col footer-brand">
                    <div class="footer-logo">
                        <i class="fas fa-bolt"></i>
                        <span>4MC</span>
                    </div>
                    <p>The premier destination for premium resources, scripts, maps, and vehicles. Built with care for the community.</p>
                </div>
                <div class="footer-col">
                    <h4>Resources</h4>
                    <ul>
                        <li><a href="#">Scripts</a></li>
                        <li><a href="#">MLO & Maps</a></li>
                        <li><a href="#">Clothing</a></li>
                        <li><a href="#">Vehicles</a></li>
                        <li><a href="#">Tools</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Community</h4>
                    <ul>
                        <li><a href="#">Discord Server</a></li>
                        <li><a href="#">Guides</a></li>
                        <li><a href="#">Toolkit</a></li>
                        <li><a href="#">Support</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Legal</h4>
                    <ul>
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">DMCA Notice</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 4MC. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="/js/script.js"></script>
</body>
</html>
