<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Access Denied - 4MC</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { background: #060606 !important; color: #fff; font-family: 'Poppins', sans-serif; }
        .denied-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; }
        .denied-card { background: rgba(10,10,15,0.9); border: 1px solid rgba(239,68,68,0.3); border-radius: 20px; padding: 40px; text-align: center; max-width: 420px; width: 100%; box-shadow: 0 24px 70px rgba(0,0,0,0.5); }
        .denied-icon { width: 60px; height: 60px; border-radius: 50%; background: rgba(239,68,68,0.15); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; }
        .denied-icon i { font-size: 1.5rem; color: #ef4444; }
        .denied-card h1 { font-size: 1.5rem; margin: 0 0 12px; }
        .denied-card p { color: rgba(255,255,255,0.6); margin: 0 0 24px; font-size: 0.95rem; line-height: 1.6; }
        .discord-join { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: linear-gradient(135deg,#5865F2 0%,#4752C4 100%); color: #fff; text-decoration: none; border-radius: 12px; font-weight: 600; font-size: 0.95rem; box-shadow: 0 8px 28px rgba(88,101,242,0.35); }
    </style>
</head>
<body>
    <div class="denied-page">
        <div class="denied-card">
            <div class="denied-icon"><i class="fas fa-shield-halved"></i></div>
            <h1>Access Denied</h1>
            <p>You must join the server to access the dashboard.</p>
            <a href="<%- DISCORD_INVITE_URL %>" target="_blank" class="discord-join">
                <i class="fab fa-discord"></i> Join Discord Server
            </a>
        </div>
    </div>
</body>
</html>
