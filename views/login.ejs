<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - 4MC</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
    <canvas id="network-canvas" class="network-canvas" aria-hidden="true"></canvas>
    <div class="grid-overlay"></div>

    <div class="bg-effects">
        <div class="glow-blob glow-blob-1"></div>
        <div class="glow-blob glow-blob-2"></div>
    </div>

    <header class="topbar">
        <a href="/" class="brand">
            <span class="brand-icon"><i class="fas fa-bolt"></i></span>
            <span class="brand-text"><strong>4MC</strong></span>
        </a>
        <a href="/" class="btn btn-ghost"><i class="fas fa-arrow-left"></i> Back to Home</a>
    </header>

    <main class="page-login">
        <div class="login-card">
            <div class="login-glow"></div>

            <div class="login-logo">
                <div class="logo-box">
                    <i class="fas fa-bolt"></i>
                </div>
                <span class="logo-text">4MC</span>
            </div>

            <h1 class="login-title">Welcome Back</h1>
            <p class="login-subtitle">Sign in with Discord to access your dashboard and premium resources</p>

            <a href="/auth/login" class="btn btn-discord btn-full" id="discord-login-btn">
                <i class="fab fa-discord"></i>
                <span>Continue with Discord</span>
            </a>

            <p class="login-note">
                <i class="fas fa-info-circle"></i>
                You must be a member of our Discord server to login
            </p>

            <div class="login-features">
                <div class="login-feature">
                    <i class="fas fa-shield-halved"></i>
                    <span>Secure</span>
                </div>
                <div class="login-feature">
                    <i class="fas fa-bolt"></i>
                    <span>Fast</span>
                </div>
                <div class="login-feature">
                    <i class="fas fa-infinity"></i>
                    <span>Free</span>
                </div>
            </div>
        </div>
    </main>

    <script src="/js/script.js"></script>
</body>
</html>
